# AAA — Autonomous AI Auditor: Environment Variables
# Copy this file to .env and fill in real values.
# Python 3.12 is REQUIRED for all services.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# PostgreSQL (used by Platform, Langfuse, Agents checkpointer)
# ---------------------------------------------------------------------------
POSTGRES_USER=aaa
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aaa
POSTGRES_PORT=5432
DATABASE_URL=postgresql://aaa:changeme@localhost:${POSTGRES_PORT}/aaa

# ---------------------------------------------------------------------------
# MinIO S3-compatible Object Store (Evidence Store)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=aaa-minio
MINIO_ROOT_PASSWORD=changeme
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false

# ---------------------------------------------------------------------------
# Valkey (Redis fork) — Queue & Cache
# ---------------------------------------------------------------------------
VALKEY_PASSWORD=changeme
REDIS_URL=redis://:changeme@localhost:6379/0

# ---------------------------------------------------------------------------
# OpenBao — Secrets Management
# ---------------------------------------------------------------------------
BAO_ADDR=http://localhost:8200
BAO_TOKEN=

# ---------------------------------------------------------------------------
# Langfuse — LLM Tracing & Observability
# ---------------------------------------------------------------------------
LANGFUSE_SECRET_KEY=changeme
LANGFUSE_PUBLIC_KEY=changeme
LANGFUSE_HOST=http://localhost:3003

# ---------------------------------------------------------------------------
# Grafana — Metrics Dashboards
# ---------------------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# LLM Provider API Keys (at least one required)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=...
MISTRAL_API_KEY=...
# OLLAMA_BASE_URL=http://localhost:11434   # Uncomment for local Ollama

# ---------------------------------------------------------------------------
# LiteLLM — Model Router Config
# ---------------------------------------------------------------------------
LITELLM_MASTER_KEY=sk-aaa-litellm

# ---------------------------------------------------------------------------
# FastAPI / Platform
# ---------------------------------------------------------------------------
PLATFORM_HOST=0.0.0.0
PLATFORM_PORT=8000
PLATFORM_SECRET_KEY=super-secret-jwt-key-change-me

# ---------------------------------------------------------------------------
# Next.js Frontend
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET=changeme
NEXTAUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Email (MailHog in dev)
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ---------------------------------------------------------------------------
# Agent Runtime
# ---------------------------------------------------------------------------
AGENT_RUNTIME_HOST=0.0.0.0
AGENT_RUNTIME_PORT=9002

# ---------------------------------------------------------------------------
# MCP Tool Servers
# ---------------------------------------------------------------------------
MCP_BASE_PORT=7001
MCP_DATA_PORT=7002
MCP_MODEL_PORT=7003
MCP_FAIRNESS_PORT=7004
MCP_GOV_PORT=7005

# ---------------------------------------------------------------------------
# AAA Pipeline Mode (python -m aaa.cli / streamlit run aaa/ui/app.py)
# ---------------------------------------------------------------------------
AAA_OFFLINE_MODE=false           # Set to 'true' to disable all HTTP calls (CI / Streamlit demo)
AAA_LOG_LEVEL=WARNING            # DEBUG | INFO | WARNING | ERROR

# ---------------------------------------------------------------------------
# S4 CGSA integration (§10.2) — used by aaa/tools/cgsa_pull.py
# ---------------------------------------------------------------------------
S4_CGSA_BASE_URL=http://localhost:8001
CGSA_SCHEMA_VERSION=1.0.0
CGSA_FIXTURE_DIR=scripts/fixtures/cgsa   # Overrides HTTP pull in offline mode
